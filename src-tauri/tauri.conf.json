{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Z3R Launcher",
  "version": "0.1.0",
  "identifier": "com.xander.z3r-launcher",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Z3R Launcher",
        "width": 1280,
        "height": 760,
        "minWidth": 1240,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Game",
    "resources": [
      "bundled-tools/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
